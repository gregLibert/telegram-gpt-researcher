# --- GPT Researcher (voir https://github.com/assafelovic/gpt-researcher) ---
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
TAVILY_API_KEY=tvly-...
# LANGCHAIN_API_KEY=

# Tag ou branche du dépôt cloné dans l’image (build ; défaut : release stable v3.4.3)
# GPT_RESEARCHER_REF=v3.4.3

# --- Réseau / ports ---
# GPTR_HOST_PORT=8000
# GPTR_API_URL=http://gpt-researcher:8000

# --- Bot Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC...
# Liste blanche : IDs numériques séparés par des virgules
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# Optionnel : répertoire d’écriture des artefacts avant envoi (volume Docker)
# BOT_ARTIFACT_DIR=/tmp/bot-artifacts

# LOG_LEVEL=INFO
# GPTR_WORKERS=1

# Bot : nombre max de recherches GPT en parallèle (1 ou 2 ; défaut 1, anti-OOM sur petit matériel)
# RESEARCH_MAX_CONCURRENT=1

# --- Images GHCR (compose “utilisateur” du README ; préfixe = owner/repo en minuscules) ---
# GHCR_IMAGE_PREFIX=your-github-username/your-repo-name
# APP_VERSION=latest
